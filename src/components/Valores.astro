---
const valores = [
  {
    number: "01",
    title: "Seguridad",
    description: "Código blindado desde la primera línea."
  },
  {
    number: "02",
    title: "Alianza", 
    description: "Creemos junto con el éxito de su proyecto."
  },
  {
    number: "03",
    title: "Innovación",
    description: "IA aplicada con sentido pragmático."
  },
  {
    number: "04",
    title: "Compromiso",
    description: "Entregas a tiempo y sin sorpresas ocultas."
  }
];
---

<section class="py-24 bg-[#09090E]">
  <div class="container mx-auto px-6">
    <h2 class="font-[family-name:var(--font-display)] font-black text-4xl uppercase tracking-tighter mb-16 text-center">
      NUESTROS <span class="text-[#E8002D]">PRINCIPIOS</span>
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      {valores.map((valor) => (
        <div class="p-6 bg-[#111118] border border-white/[0.07] group hover:bg-[#1A1A24] transition-all hover:border-[#0057FF]/30">
          <span class="font-[family-name:var(--font-mono)] text-[10px] text-[#E8002D] block mb-4">{valor.number}. PRINCIPLE</span>
          <h4 class="font-[family-name:var(--font-display)] font-bold text-xl uppercase mb-2">{valor.title}</h4>
          <p class="text-white/50 text-sm font-[family-name:var(--font-body)]">{valor.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>