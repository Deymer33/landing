---
const diferenciales = [
  {
    number: "01",
    title: "No trabajamos solos",
    description: "Somos sus aliados tecnológicos, no un proveedor externo. Nos sumergimos en su negocio para entender el 'por qué' antes del 'cómo'."
  },
  {
    number: "02", 
    title: "Seguro por diseño",
    description: "La seguridad no es una capa final, es el cimiento. Cada línea de código es auditada con estándares de ciberseguridad internacionales."
  },
  {
    number: "03",
    title: "Precio real para Colombia",
    description: "Calidad de Silicon Valley con estructura de costos local. Optimizamos recursos para que cada peso invertido genere valor tangible."
  }
];
---

<section class="relative py-40 bg-[#E8002D] overflow-hidden diagonal-cut my-[-5vw] z-20" id="diferencial">
  <!-- Noise texture overlay -->
  <div class="absolute inset-0 opacity-10 mix-blend-overlay pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>
  
  <div class="container mx-auto px-6 relative z-10">
    <h2 class="font-[family-name:var(--font-display)] font-black text-5xl md:text-7xl text-white uppercase tracking-tighter mb-24">
      POR QUÉ DEI ARTETA <br/>ES DIFERENTE
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-8 lg:gap-16">
      {diferenciales.map((item) => (
        <div class="flex flex-col items-center md:items-start text-center md:text-left">
          <span class="font-[family-name:var(--font-display)] font-black text-9xl text-white/20 mb-[-40px]">{item.number}</span>
          <h3 class="font-[family-name:var(--font-display)] font-bold text-3xl text-white uppercase mb-6 mt-4">{item.title}</h3>
          <p class="text-white/90 font-[family-name:var(--font-body)] font-light leading-relaxed text-lg">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>