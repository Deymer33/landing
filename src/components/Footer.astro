---
const currentYear = new Date().getFullYear();

const footerLinks = [
  { label: "Servicios", href: "#servicios" },
  { label: "Proceso", href: "#proceso" },
  { label: "Diferencial", href: "#diferencial" },
  { label: "Contacto", href: "#contacto" }
];
---

<footer class="bg-[#09090E] relative overflow-hidden">
  <!-- Gradient Separator -->
  <div class="w-full h-[1px] bg-gradient-to-r from-[#E8002D] via-[#0057FF] to-transparent"></div>
  
  <div class="flex flex-col md:flex-row justify-between items-center px-6 md:px-12 py-16 gap-8 max-w-7xl mx-auto">
    <!-- Logo & Description -->
    <div class="flex flex-col gap-4 items-center md:items-start">
      <div class="font-[family-name:var(--font-display)] font-bold text-lg text-white uppercase flex items-baseline gap-2">
        DEI ARTETA <span class="text-[#E8002D] text-[10px] tracking-widest font-[family-name:var(--font-mono)]">LABS</span>
      </div>
      <p class="font-[family-name:var(--font-body)] font-light text-sm text-white/40 max-w-xs text-center md:text-left">
        Ingeniería de software de alto impacto diseñada y ejecutada desde Colombia para el mundo.
      </p>
    </div>
    
    <!-- Nav Links -->
    <div class="flex gap-8">
      {footerLinks.map((link) => (
        <a 
          href={link.href}
          class="text-white/60 font-[family-name:var(--font-body)] font-light text-sm hover:text-white transition-all opacity-80 hover:opacity-100"
        >
          {link.label}
        </a>
      ))}
    </div>
    
    <!-- Copyright -->
    <div class="text-white/40 font-[family-name:var(--font-body)] font-light text-xs">
      Dei Arteta Software Solutions © {currentYear} — Colombia
    </div>
  </div>
</footer>