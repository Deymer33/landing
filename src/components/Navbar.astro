---
const navLinks = [
  { label: "Servicios", href: "#servicios" },
  { label: "Proceso", href: "#proceso" },
  { label: "Diferencial", href: "#diferencial" },
  { label: "Contacto", href: "#contacto" }
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-[#09090E]/80 backdrop-blur-xl border-b border-white/[0.07]">
  <div class="max-w-7xl mx-auto px-6 md:px-12 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-baseline gap-1 group">
      <span class="font-[family-name:var(--font-display)] font-bold text-2xl uppercase tracking-tight text-white">
        DEI ARTETA
      </span>
      <span class="text-white/50 text-xs font-[family-name:var(--font-body)] font-light tracking-widest hidden md:inline ml-2">
        SOFTWARE SOLUTIONS
      </span>
    </a>

    <!-- Desktop Nav Links -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a 
          href={link.href}
          class="text-white/70 font-[family-name:var(--font-body)] font-light tracking-wide hover:text-[#E8002D] transition-colors duration-300"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- CTA Button -->
    <a 
      href="#contacto"
      class="bg-[#E8002D] hover:bg-[#9B001E] text-white px-6 py-2 font-[family-name:var(--font-display)] font-bold uppercase tracking-wider transition-all active:scale-95"
    >
      Agendar llamada
    </a>
  </div>
</nav>