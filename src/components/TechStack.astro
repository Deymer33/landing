---
const tecnologias = [
  "Python", "Node.js", "React", "Astro", "Docker", 
  "PostgreSQL", "AWS", "GCP", "FastAPI", "LangChain", 
  "Terraform", "GitHub Actions"
];
---

<section class="py-24 bg-[#FFFFFF] border-y border-black/[0.07]">
  <div class="container mx-auto px-6">
    <h2 class="font-[family-name:var(--font-display)] font-black text-4xl uppercase tracking-tight mb-12 text-center text-[#1A1A1A]">
      TECNOLOGÍAS <span class="text-[#0057FF]">ELITE</span>
    </h2>
    
    <div class="flex flex-wrap justify-center gap-4">
      {tecnologias.map((tech) => (
        <span class="px-6 py-2 bg-[#F5F5F5] border border-black/20 text-[#1A1A1A] font-[family-name:var(--font-mono)] text-sm hover:bg-[#0057FF]/20 transition-all cursor-default">
          {tech}
        </span>
      ))}
    </div>
  </div>
</section>