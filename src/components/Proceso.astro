---
const pasos = [
  {
    number: "01",
    title: "Descubrimiento",
    description: "Análisis profundo de requerimientos y definición de KPIs de éxito."
  },
  {
    number: "02",
    title: "Arquitectura", 
    description: "Diseño del blueprint técnico y selección del stack tecnológico óptimo."
  },
  {
    number: "03",
    title: "Desarrollo Ágil",
    description: "Sprints de entrega continua con visibilidad total del progreso."
  },
  {
    number: "04",
    title: "QA y Auditoría",
    description: "Pruebas rigurosas de carga, estrés y vulnerabilidades."
  },
  {
    number: "05",
    title: "Lanzamiento y Soporte",
    description: "Despliegue monitoreado y acompañamiento técnico permanente."
  }
];
---

<section class="py-32 bg-[#09090E] pt-48" id="proceso">
  <div class="container mx-auto px-6">
    <!-- Section Title -->
    <div class="text-center mb-24">
      <h2 class="font-[family-name:var(--font-display)] font-black text-5xl md:text-6xl uppercase tracking-tighter mb-4">
        CÓMO <span class="text-[#E8002D]">TRABAJAMOS</span>
      </h2>
      <div class="w-24 h-1 bg-[#E8002D] mx-auto"></div>
    </div>
    
    <!-- Timeline -->
    <div class="relative max-w-4xl mx-auto">
      <!-- Vertical Line -->
      <div class="absolute left-0 md:left-1/2 md:-translate-x-1/2 top-0 bottom-0 w-[1px] bg-white/10"></div>
      
      {pasos.map((paso, index) => (
        <div class={`relative mb-12 md:flex items-center justify-between ${index % 2 === 1 ? 'flex-row-reverse' : ''}`}>
          {/* Left side (or right on alternating) */}
          <div class={`md:w-5/12 ml-8 md:ml-0 ${index % 2 === 1 ? '' : 'md:text-right'}`}>
            <span class="font-[family-name:var(--font-display)] font-black text-4xl text-[#E8002D]">{paso.number}</span>
            <h4 class="font-[family-name:var(--font-display)] font-bold text-xl uppercase mt-2">{paso.title}</h4>
            <p class="text-white/60 font-[family-name:var(--font-body)] font-light mt-2">{paso.description}</p>
          </div>
          
          {/* Center dot */}
          <div class="absolute left-[-5px] md:left-1/2 md:-translate-x-1/2 w-3 h-3 bg-[#E8002D] rounded-full ring-8 ring-[#09090E]"></div>
          
          {/* Right side (or left on alternating) */}
          <div class="md:w-5/12 hidden md:block"></div>
        </div>
      ))}
    </div>
  </div>
</section>